# ============================================
# FoxBrain RAG Demo — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- FoxBrain API (Generation) ---
FOXBRAIN_BASE_URL=http://4.151.237.144:8000/v1
FOXBRAIN_API_KEY=token-abc123
FOXBRAIN_MODEL=20251203_remove_repeat

# --- OpenAI API (Embedding + THELMA Judge) ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
THELMA_JUDGE_MODEL=gpt-4o-mini

# --- RAG Retrieval Settings ---
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150
RAG_TOP_K_RETRIEVE=20
RAG_TOP_K_RERANK=8
RAG_BM25_WEIGHT=0.4

# --- Vector DB ---
VECTOR_DB_PATH=./data/milvus.db
VECTOR_DB_COLLECTION=rag_collection

# --- Generation Settings ---
GENERATION_TEMPERATURE=0.3
GENERATION_MAX_TOKENS=1024

# --- THELMA Evaluation ---
THELMA_MAX_CONCURRENCY=8

# --- Server ---
HOST=0.0.0.0
PORT=8080

# --- Cloud Deploy ---
# Set to true to auto-process documents/ on startup (Render, Railway, etc.)
AUTO_PROCESS=false
